# ============================================================
# ERP SAF — Variáveis de ambiente (backend)
# Copie como .env para desenvolvimento local
# No Railway: configure em Settings → Variables
# ============================================================

# ─── Banco de Dados ─────────────────────────────────────────
# Railway injeta DATABASE_URL automaticamente ao conectar o plugin PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# (Alternativa: variáveis individuais para dev local)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=erp_saf
# DB_USER=postgres
# DB_PASS=

# ─── JWT ────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_STRING_ALEATORIA_64_CHARS
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXP=7d

# ─── Servidor ────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Frontend (CORS) ─────────────────────────────────────────
# URL do frontend no Netlify (sem barra final)
FRONTEND_URL=https://seu-erp.netlify.app

# ─── Bcrypt ──────────────────────────────────────────────────
SALT_ROUNDS=12

# ─── Migração / Seed ──────────────────────────────────────────
# Senha inicial do admin (usada em migrate.js se definida)
# Gere uma senha forte e remova após o primeiro deploy
ADMIN_SEED_PASSWORD=TROQUE_POR_SENHA_FORTE
ADMIN_EMAIL=ceo@riobrancosaf.com.br

# ─── Seed Demo (seed_demo.js) ─────────────────────────────────
# Chave adicional para o endpoint /api/seed-demo (requer JWT admin também)
SEED_SECRET=TROQUE_POR_STRING_ALEATORIA
