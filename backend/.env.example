# ============================================================
# ERP SAF — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus dados REAIS
# NUNCA envie o arquivo .env para o Git!
# ============================================================

# ── OPÇÃO 1: URL única (Railway fornece isso automaticamente) ──
# DATABASE_URL=postgresql://user:senha@host:5432/banco

# ── OPÇÁO 2: variáveis individuais (local/dev) ────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=erp_saf
DB_USER=postgres
DB_PASSWORD=SUA_SENHA_AQUI

# ── JWT ───────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_UMA_CHAVE_MUITO_SEGURA_AQUI_MINIMO_64_CHARS
JWT_EXPIRES_IN=8h

# ── Servidor ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS — URL do frontend no Netlify ─────────────────────────
# Após criar o site no Netlify, cole a URL aqui (ex: https://erp-saf.netlify.app)
FRONTEND_URL=https://SEU-SITE.netlify.app
